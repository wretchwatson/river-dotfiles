#!/bin/sh

# 1. Ortam Değişkenleri (Her Şeyden Önce)
export XDG_CURRENT_DESKTOP=river
export XDG_SESSION_DESKTOP=river
export XDG_SESSION_TYPE=wayland
export XCURSOR_THEME=capitaine-cursors-light
export XCURSOR_SIZE=24

# Uygulama uyumlulukları için (Özellikle Electron/Chrome/QT)
export MOZ_ENABLE_WAYLAND=1
export QT_QPA_PLATFORM="wayland;xcb"
export ELECTRON_OZONE_PLATFORM_HINT=auto
export _JAVA_AWT_WM_NONREPARENTING=1
export SDL_VIDEODRIVER=wayland

# NVIDIA VA-API (Donanım hızlandırmalı video decode için)
export LIBVA_DRIVER_NAME=nvidia
export NVD_BACKEND=direct

# Systemd ve DBus'ı bilgilendir
dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP XDG_SESSION_TYPE XCURSOR_THEME XCURSOR_SIZE
systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP XDG_SESSION_TYPE XCURSOR_THEME XCURSOR_SIZE

# 2. Portal ve Temel Servisler (Environment hazır olduktan sonra)
systemctl --user restart xdg-desktop-portal xdg-desktop-portal-wlr
/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 &

# 3. Ekran ve Monitör (Adaptive Sync)
wlr-randr --output DP-1 --mode 1920x1080@239.964 --adaptive-sync disabled

# 4. Input ve Cursor
riverctl keyboard-layout tr
riverctl set-repeat 50 300
riverctl xcursor-theme capitaine-cursors-light 24
riverctl border-width 2

# 5. Kısayollar (Keybindings)
# Temel
riverctl map normal Super Return spawn kitty
riverctl map normal Super Q close
riverctl map normal Super+Shift M exit
riverctl map normal Super+Shift R spawn 'sh ~/.config/river/init'

# Uygulamalar
riverctl map normal Super W spawn 'google-chrome-stable --profile-directory="Default"'
riverctl map normal Super+Shift W spawn 'google-chrome-stable --incognito'
riverctl map normal Super G spawn  antigravity
riverctl map normal Super E spawn 'kitty -e yazi'
riverctl map normal Super A spawn 'wofi --show drun'
riverctl map normal Super X spawn 'wlogout -b 6'
riverctl map normal Super B spawn /home/ridvan/.config/river/scripts/wallpaper-picker.sh
riverctl map normal Super V spawn "cliphist list | wofi --dmenu | cliphist decode | wl-copy"
riverctl map normal Super P spawn '/home/ridvan/.config/river/scripts/swaylock.sh'
riverctl map normal Super Y spawn 'mpv "$(wl-paste)"'

# Screenshot
riverctl map normal Super S spawn 'grim ~/Resimler/$(date +%Y-%m-%d_%H-%m-%s).png && notify-send "📸 Ekran Görüntüsü" "Tam ekran ~/Resimler altına kaydedildi!"'
riverctl map normal Super+Shift S spawn 'grim -g "$(slurp)" ~/Resimler/$(date +%Y-%m-%d_%H-%m-%s).png && notify-send "📸 Ekran Görüntüsü" "Seçili alan ~/Resimler altına kaydedildi!"'

# Layout ve Pencere Yönetimi
riverctl map normal Super J focus-view next
riverctl map normal Super K focus-view previous
riverctl map normal Super+Shift J swap next
riverctl map normal Super+Shift K swap previous
riverctl map normal Alt Tab zoom

riverctl map normal Super H send-layout-cmd rivercarro "main-ratio -0.05"
riverctl map normal Super L send-layout-cmd rivercarro "main-ratio +0.05"
riverctl map normal Super+Shift H send-layout-cmd rivercarro "main-count +1"
riverctl map normal Super+Shift L send-layout-cmd rivercarro "main-count -1"

riverctl map normal Super Up    send-layout-cmd rivercarro "main-location top"
riverctl map normal Super Right send-layout-cmd rivercarro "main-location right"
riverctl map normal Super Down  send-layout-cmd rivercarro "main-location bottom"
riverctl map normal Super Left  send-layout-cmd rivercarro "main-location left"
riverctl map normal Super M     send-layout-cmd rivercarro "main-location monocle"

# Boşluklar (Gaps)
riverctl map normal Super Plus send-layout-cmd rivercarro "gaps +1"
riverctl map normal Super Minus send-layout-cmd rivercarro "gaps -1"

# Mouse Mappings
riverctl map-pointer normal Super BTN_LEFT move-view
riverctl map-pointer normal Super BTN_RIGHT resize-view
riverctl map-pointer normal Super BTN_MIDDLE toggle-float

# Tags (1-9)
for i in $(seq 1 9); do
    tags=$((1 << ($i - 1)))
    riverctl map normal Super $i set-focused-tags $tags
    riverctl map normal Super+Shift $i set-view-tags $tags
    riverctl map normal Super+Control $i toggle-focused-tags $tags
    riverctl map normal Super+Shift+Control $i toggle-view-tags $tags
done

all_tags=$(((1 << 32) - 1))
riverctl map normal Super 0 set-focused-tags $all_tags
riverctl map normal Super+Shift 0 set-view-tags $all_tags
riverctl map normal Super Space toggle-float
riverctl map normal Super F toggle-fullscreen
riverctl map normal Super+Shift P set-view-tags $all_tags

# Passthrough Mode
riverctl declare-mode passthrough
riverctl map normal Super F11 enter-mode passthrough
riverctl map passthrough Super F11 enter-mode normal

# Media Keys
for mode in normal locked; do
    riverctl map $mode None XF86AudioRaiseVolume  spawn 'pamixer -i 5'
    riverctl map $mode None XF86AudioLowerVolume  spawn 'pamixer -d 5'
    riverctl map $mode None XF86AudioMute         spawn 'pamixer --toggle-mute'
    riverctl map $mode None XF86AudioPlay  spawn 'playerctl play-pause'
    riverctl map $mode None XF86AudioPrev  spawn 'playerctl previous'
    riverctl map $mode None XF86AudioNext  spawn 'playerctl next'
    riverctl map $mode None XF86MonBrightnessUp   spawn 'brightnessctl set +5%'
    riverctl map $mode None XF86MonBrightnessDown spawn 'brightnessctl set 5%-'
done

# 6. Görsel Ayarlar ve Renkler
riverctl background-color 0x0f0a24
riverctl border-color-focused 0x5D378B
riverctl border-color-unfocused 0x9f8492
riverctl border-color-urgent 0xFF0000

# Bütün uygulamalarda CSD'yi kapatıp SSD'yi (River'ın kendi kenarlıklarını) zorla
riverctl rule-add -app-id '*' ssd
riverctl rule-add -app-id 'pavucontrol' float
riverctl rule-add -app-id 'azote' float
riverctl rule-add -app-id 'nm-connection-editor' float
riverctl rule-add -app-id 'wlogout' float
riverctl rule-add -title 'File Operation Progress' float

# 7. Yan Servisleri Başlat (Daemons)
killall -q waybar mako wl-paste
waybar &
mako &
wl-paste --type text --watch cliphist store &
wl-paste --type image --watch cliphist store &

# Boşta kalma yönetimi (5 dk sonra kilitler, 10 dk sonra ekranı kapatır)
swayidle -w \
    timeout 300 '/home/ridvan/.config/river/scripts/swaylock.sh' \
    timeout 600 'riverctl spawn "wlr-randr --output DP-1 --off"' \
    resume 'riverctl spawn "wlr-randr --output DP-1 --on"' \
    before-sleep '/home/ridvan/.config/river/scripts/swaylock.sh' &

# Duvar Kağıdı ve Pywal (No-wallpaper bayrağı ile çökmeyi önleyelim)
if [ -f "$HOME/.azotebg" ]; then
    sh "$HOME/.azotebg" &
    wal -R -q -n
fi

# 8. Layout Generator'ı Başlat (Final)
riverctl default-layout rivercarro
riverctl send-layout-cmd rivercarro "main-location right"
riverctl send-layout-cmd rivercarro "main-ratio 0.5"
exec rivercarro -per-tag -no-smart-gaps -inner-gaps 5 -outer-gaps 5
