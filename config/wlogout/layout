{
    "label": "lock",
    "action": "/home/ridvan/.config/river/scripts/swaylock.sh",
    "text": "Kilitle",
    "keybind": "l"
}

{
    "label": "logout",
    "action": "riverctl exit",
    "text": "Çıkış Yap",
    "keybind": "e"
}

{
    "label": "suspend",
    "action": "/home/ridvan/.config/river/scripts/swaylock.sh & disown && systemctl suspend",
    "text": "Askıya Al",
    "keybind": "u"
}

{
    "label": "shutdown",
    "action": "systemctl poweroff",
    "text": "Kapat",
    "keybind": "s"
}

{
    "label": "hibernate",
    "action": "/home/ridvan/.config/river/scripts/swaylock.sh & disown && systemctl hibernate",
    "text": "Uyut",
    "keybind": "h"
}

{
    "label": "reboot",
    "action": "systemctl reboot",
    "text": "Yeniden Başlat",
    "keybind": "r"
}